# .env の見本。`.env` にコピーして実値を入れる（.env は Git 管理外）。

# === Django 設定 ===
# 長いランダム文字列。生成例:
#   uv run python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=change_me_to_a_random_string
# 開発=True / 本番=False（本番は必ず False。HTTPS系セキュリティ設定が有効になる）
DJANGO_DEBUG=True
# このサーバが応答するホスト名（カンマ区切り）。開発=localhost,127.0.0.1 / 本番=独自ドメイン
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# 本番(HTTPS)のみ必要。HTTPSドメインからの POST(ログイン等)を許可。https:// を付ける。
# 開発では空でよい。例: https://ec.komaki-wms.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# === PostgreSQL 接続設定 ===
# 同じ AWS RDS インスタンス内の "ec" データベースを使う（WMS は "wms" データベース）。
# 開発=localhost（WMS と同じ Postgres コンテナ内の ec データベース） / 本番=RDS エンドポイント
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ec
POSTGRES_USER=ec
POSTGRES_PASSWORD=change_me

# === EC frontend からの CORS 許可オリジン（カンマ区切り） ===
# 本番のみ指定。例: https://ec.komaki-wms.com
# 開発(DEBUG=True)は localhost:5173 等を自動許可するので空でよい。
DJANGO_CORS_ALLOWED_ORIGINS=

# === WMS 連携（EC backend → WMS backend の API 呼び出し） ===
# WMS backend のベース URL。開発=http://localhost:8000 / 本番=https://komaki-wms.com
WMS_BASE_URL=http://localhost:8000
# WMS と共有する API キー（サービス間認証）。WMS 側 .env の WMS_API_KEY と同じ値にする。
# Authorization: Bearer <この値> を WMS へのリクエストに付与する。
WMS_API_KEY=change_me
